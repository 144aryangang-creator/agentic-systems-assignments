from fastapi import FastAPI
from typing import Optional

app = FastAPI()

@app.get("/search")
async def search_users(name: Optional[str] = None, age: Optional[int] = None):
    """
    Endpoint that accepts optional query parameters 'name' and 'age'.
    If no parameters are provided, it returns null/None for those fields.
    """
    return {
        "name": name,
        "age": age
    }
